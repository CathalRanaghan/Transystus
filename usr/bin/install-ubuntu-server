set -euo pipefail

TRANS_BIN="$(dirname "${BASH_SOURCE[0]}")"
TRANS_ROOT="$TRANS_BIN/../../"
TRANS_LIB="$TRANS_ROOT/usr/lib/transystus"
TRANS_VAR="$TRANS_ROOT/var"

source "$TRANS_LIB/common-lib"

check_root_and_lock_status

LOG_DIR="$TRANS_VAR/log/transystus/ubuntu-desktop-to-server"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/migration-output-log-$TIMESTAMP.log"

(
### START MIGRATION ###

# Section 1: System Update
set_section "System Update"

log INFO "Updating system..." 
run "" update_system

# Section 2: Plymouth
set_section "Plymouth Boot"
log INFO "Removing splash screen..." remove_plymouth

# Section 3: Ubuntu Server Packages
set_section "Server Packages"

log INFO "Installing Ubuntu Server Packages..."
run "Ubuntu Server package installation failed." apt install -y "${UBUNTU_SERVER_PACKAGES[@]}"

# Section 4: Package Flags
set_section "Package Marking"

log INFO "Marking Ubuntu Server packages automatically installed to align with a standard install..."
run "Not all packages marked auto." apt-mark auto "${UBUNTU_SERVER_AUTOMATIC_PACKAGES[@]}"

log INFO "Marking Ubuntu Server packages manually installed to align with a standard install..."
run "Not all packages marked manual." apt-mark manual "${UBUNTU_SERVER_MANUAL_PACKAGES[@]}"

# Section 5: Ubuntu Desktop Packages
set_section "Desktop Packages"

log INFO "Removing Ubuntu Desktop Packages..."
run "Ubuntu Desktop package installation failed." remove_ubuntu_desktop_packages

# Section 5: Snap Packages
set_section "Snap Removal"

log INFO "Removing Snap Packages..." 
run "Snap Packages failed to be removed" remove_ubuntu_desktop_snaps

# Section 6: System Configuration
set_section "System Configuration"

log INFO "Adding Ubuntu Server Cofiguration..."
run "Unable to add Ubuntu Server Cofiguration." add_ubuntu_server_config

log INFO "Removing Ubuntu Desktop Cofiguration..."
run "Unable to remove Ubuntu Desktop Cofiguration." remove_ubuntu_desktop_config_and_data

### END MIGRATION ###

) 2>&1 | tee "$LOG_FILE"

log INFO "Migration complete."

confirm_reboot