add_ubuntu_server_config()
{

    # Functions adding configs must have their own initialization variables because the global ones aren't available in libraries that will be sourced by Common-Lib
    local EXEC_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local TRANS_ROOT="$(cd "$EXEC_DIR/../../../.." && pwd)"
    local TRANS_BIN="$TRANS_ROOT/usr/bin"
    local TRANS_LIB="$TRANS_ROOT/usr/lib/transystus"
    local TRANS_VAR="$TRANS_ROOT/usr/var"
    local ETC_DIRS=(apparmor.d cloud/clean.d cloud/cloud.cfg.d default multipath netplan pollinate)

    systemctl enable --now systemd-networkd
    
    if [[ -f /etc/default/grub ]]; then
            mv /etc/default/grub /etc/default/grub.bak
    fi

    for dir in "${ETC_DIRS[@]}"; do
        mkdir -p "/etc/$dir"
        cp -rv "$TRANS_LIB/Ubuntu Server Assets/etc/$dir/." "/etc/$dir/"
    done

    chmod 644 /etc/default/grub /etc/default/grub.ucf-dist
    update-grub
}

remove_ubuntu_server_config_and_data()
{
    for group in "${UBUNTU_SERVER_GROUPS_TO_REMOVE[@]}"; do
            if ! groupdel "$group" 2>/dev/null || true; then
                echo "Warning: '$group' could not be removed."
            else
                echo "Removed group: '$group'"
            fi
    done

    for file in "${UBUNTU_SERVER_CONFIG_FILES_TO_REMOVE[@]}"; do
            if ! rm -fv "$file"; then
                echo "Warning: '$file' could not be removed."
            fi
    done

    for file in "${UBUNTU_SERVER_VAR_FILES_TO_REMOVE[@]}"; do
            if ! rm -fv "$file"; then
                echo "Warning: '$file' could not be removed."
            fi
    done

    for dir in "${UBUNTU_SERVER_CONFIG_DIRS_TO_REMOVE[@]}"; do
            if ! rmdir -v "$dir" 2>/dev/null; then
                echo "Warning: '$dir' could not be removed."
            fi
    done

    for dir in "${UBUNTU_SERVER_VAR_DIRS_TO_REMOVE[@]}"; do
            if ! rm -rfv "$dir"; then
                echo "Warning: '$dir' could not be removed."
            fi
    done
}

