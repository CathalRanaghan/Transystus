add_ubuntu_desktop_config()
{

    # Functions adding configs must have their own initialization variables because the global ones aren't available in libraries that will be sourced by Common-Lib
    local EXEC_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local TRANS_ROOT="$(cd "$EXEC_DIR/../../../.." && pwd)"
    local TRANS_BIN="$TRANS_ROOT/usr/bin"
    local TRANS_LIB="$TRANS_ROOT/usr/lib/transystus"
    local TRANS_VAR="$TRANS_ROOT/usr/var"
    local ETC_DIRS=("apparmor.d" "apt/preferences.d.save/preferences.d" "cloud/clean.d" "cloud/cloud.cfg.d" "default" "netplan" "systemd/system")

    if [[ -f /etc/default/grub ]]; then
            mv /etc/default/grub /etc/default/grub.bak
    fi
    
    dpkg-reconfigure tzdata
    groupadd -rf gamemode

    for dir in "${ETC_DIRS[@]}"; do
        mkdir -p "/etc/$dir"
        cp -rv "$TRANS_LIB/Ubuntu Desktop Assets/etc/$dir/." "/etc/$dir/"
    done

    chmod 644 /etc/default/grub
    update-grub
}

install_ubuntu_desktop_snaps() {
    for snap in "${UBUNTU_DESKTOP_SNAPS_TO_INSTALL[@]}"; do

        if snap list "$snap" >/dev/null 2>&1; then
            echo "$snap is already installed — skipping"
            continue
        fi

        echo "Installing $snap..."

        if ! sudo snap install "$snap"; then
            echo "Snap install failed for $snap"
        fi

    done
}

remove_ubuntu_desktop_config_and_data()
{

    for service in "${UBUNTU_SERVER_SERVICES_TO_DISABLE[@]}"; do
        systemctl disable --now "$service"
    done

    for user in "${UBUNTU_DESKTOP_USERS_TO_REMOVE[@]}"; do
        if ! userdel "$user" 2>/dev/null || true; then
            echo "Warning: '$user' could not be removed."
        else
            echo "Removed user: '$user'"
        fi
    done

    for group in "${UBUNTU_DESKTOP_GROUPS_TO_REMOVE[@]}"; do
        if ! groupdel "$group" 2>/dev/null || true; then
            echo "Warning: '$group' could not be removed."
        else
            echo "Removed group: '$group'"
        fi
    done

    for file in "${UBUNTU_DESKTOP_CONFIG_FILES_TO_REMOVE[@]}"; do
        if ! rm -fv "$file"; then
            echo "Warning: '$file' could not be removed."
        fi
    done

    for file in "${UBUNTU_DESKTOP_VAR_FILES_TO_REMOVE[@]}"; do
        if ! rm -fv "$file"; then
            echo "Warning: '$file' could not be removed."
        fi
    done

    for dir in "${UBUNTU_DESKTOP_CONFIG_DIRS_TO_REMOVE[@]}"; do
        if ! rmdir -v "$dir" 2>/dev/null; then
            echo "Warning: '$dir' could not be removed."
        fi
    done

    for dir in "${UBUNTU_DESKTOP_VAR_DIRS_TO_REMOVE[@]}"; do
        if ! rm -rfv "$dir"; then
            echo "Warning: '$dir' could not be removed."
        fi
    done
}

remove_ubuntu_desktop_packages()
{
    apt --autoremove purge -y "${UBUNTU_DESKTOP_PACKAGES[@]}" "${UBUNTU_DESKTOP_LEFTOVER_PACKAGES[@]}" "${UBUNTU_DESKTOP_32BIT_PACKAGES[@]}" && \
    apt install -y lsb-base && apt-mark auto lsb-base # restoring lsb-base because it was removed alongside the Ubuntu Desktop packages, but is included in a clean Ubuntu Server install
}
remove_ubuntu_desktop_snaps()
{
    for snap in "${UBUNTU_DESKTOP_SNAPS_TO_REMOVE[@]}"; do
        if snap list "$snap" >/dev/null 2>&1; then
            snap remove "$snap"
        fi
    done

    for snap in "${CORE_SNAPS_TO_REMOVE[@]}"; do
        if snap list "$snap" >/dev/null 2>&1; then
            if ! snap remove "$snap"; then
                echo "$snap could not be removed."
            fi
        fi
    done

    if snap list snapd >/dev/null 2>&1; then
        snap remove snapd || true
    fi

    while IFS= read -r snap; do
        snap forget "$snap"
    done < <(get_snap_ids)
}

